# ── Google Sheets ──────────────────────────────────────────
# ID del Google Spreadsheet (está en la URL: /spreadsheets/d/ESTE_ID/edit)
SPREADSHEET_ID=tu_spreadsheet_id_aqui

# Rango de la hoja (nombre de hoja y columnas)
# Ajusta "Cursos" al nombre real de tu hoja y las columnas según tu estructura
SHEET_RANGE=Cursos!A:J

# ── Autenticación Google (elige una opción) ─────────────────

# OPCIÓN A (Recomendada para Render): pega el JSON completo de la Service Account
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# OPCIÓN B (Desarrollo local): ruta al archivo credentials.json
# GOOGLE_KEY_FILE=credentials.json

# ── Servidor ────────────────────────────────────────────────
PORT=3000
